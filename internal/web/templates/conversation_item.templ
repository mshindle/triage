package templates

import (
	"fmt"
	"net/url"
	"strings"
	"time"

	"github.com/mshindle/triage/internal/store"
)

templ conversationItem(conv store.ConversationSummary) {
	<li
		id={ "conv-" + conv.Identity }
		role="option"
		aria-selected="false"
		class="flex items-start gap-3 px-3 py-3 cursor-pointer hover:bg-blue-50 transition-colors group"
		hx-get={ "/conversations/" + url.PathEscape(conv.Identity) + "/thread" }
		hx-target="#thread-panel"
		hx-swap="innerHTML"
		hx-push-url="false"
	>
		<!-- Avatar -->
		<div class={ "flex-shrink-0 w-10 h-10 rounded-full flex items-center justify-center text-xs font-bold text-white select-none", convAvatarBg(conv.HighestPriority) } aria-hidden="true">
			{ convInitials(conv) }
		</div>
		<!-- Info column -->
		<div class="flex-1 min-w-0">
			<div class="flex items-center justify-between gap-1">
				<span class={ "text-sm truncate", convNameStyle(conv.HighestPriority) }>
					{ conv.DisplayName() }
				</span>
				<time class="text-[10px] text-slate-400 flex-shrink-0 tabular-nums">
					{ convRelativeTime(conv.LastMessageAt) }
				</time>
			</div>
			<p class="text-xs text-slate-500 truncate mt-0.5 leading-snug">{ conv.LastPreview }</p>
			<div class="flex items-center gap-1.5 mt-1.5">
				<span
					class={ "w-2 h-2 rounded-full flex-shrink-0", priorityDotColor(conv.HighestPriority) }
					aria-hidden="true"
				></span>
				<span class="sr-only">{ priorityLabel(conv.HighestPriority) } priority</span>
				@categoryPill(conv.LastCategory)
				if conv.IsGroup() {
					<span class="text-[10px] text-slate-400 bg-slate-100 px-1.5 py-0.5 rounded">group</span>
				}
			</div>
		</div>
	</li>
}

func convAvatarBg(priority int) string {
	switch {
	case priority >= 70:
		return "bg-red-500"
	case priority >= 40:
		return "bg-amber-500"
	default:
		return "bg-blue-400"
	}
}

func convInitials(conv store.ConversationSummary) string {
	name := conv.DisplayName()
	if len(name) == 0 {
		return "?"
	}
	// Phone numbers like "+15551234567" → show last 4 digits
	if strings.HasPrefix(name, "+") && len(name) >= 4 {
		return name[len(name)-4:]
	}
	// Group IDs or other names → first 2 chars uppercase
	r := []rune(strings.ToUpper(name))
	if len(r) >= 2 {
		return fmt.Sprintf("%c%c", r[0], r[1])
	}
	if len(r) == 1 {
		return string(r[0:1])
	}
	return "?"
}

func convNameStyle(priority int) string {
	if priority >= 70 {
		return "font-bold text-slate-900"
	}
	return "font-medium text-slate-700"
}

func priorityDotColor(priority int) string {
	switch {
	case priority >= 70:
		return "bg-red-500"
	case priority >= 40:
		return "bg-amber-400"
	default:
		return "bg-green-400"
	}
}

func convRelativeTime(t time.Time) string {
	d := time.Since(t)
	switch {
	case d < time.Minute:
		return "now"
	case d < time.Hour:
		return fmt.Sprintf("%dm", int(d.Minutes()))
	case d < 24*time.Hour:
		return fmt.Sprintf("%dh", int(d.Hours()))
	default:
		return t.Format("Jan 2")
	}
}
