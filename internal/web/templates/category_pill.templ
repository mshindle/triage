package templates

// categoryPill renders a small uppercase category badge.
// If category is empty it renders nothing.
templ categoryPill(category string) {
	if category != "" {
		<span class="inline-block px-2 py-0.5 rounded text-[10px] font-medium uppercase tracking-wide bg-slate-100 text-slate-500">
			{ category }
		</span>
	}
}
